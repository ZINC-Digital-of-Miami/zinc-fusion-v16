+from pathlib import Path
+
+import pytest
+
+
+ROOT = Path(__file__).resolve().parents[2]
+
+
+@pytest.mark.xfail(strict=True, reason="BUG-003: remove marker after applying quality/patches/BUG-003-fix.patch")
+def test_bug_003_ingest_status_vocabulary_is_single_set() -> None:
+    intraday_sql = (ROOT / "supabase/migrations/20260414001_ingest_zl_intraday.sql").read_text(encoding="utf-8")
+    trusted_fill_sql = (ROOT / "supabase/migrations/202605080003_supabase_trusted_site_fill_hourly.sql").read_text(encoding="utf-8")
+
+    # SQL writers should persist the same canonical status set used by TS helpers.
+    assert "'RUNNING'" in intraday_sql
+    assert "'SUCCESS'" in intraday_sql
+    assert "'FAILED'" in intraday_sql
+
+    assert "'RUNNING'" in trusted_fill_sql
+    assert "'SUCCESS'" in trusted_fill_sql
+    assert "'FAILED'" in trusted_fill_sql
