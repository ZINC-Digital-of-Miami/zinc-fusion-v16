# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Required for auth email redirects in non-local environments
NEXT_PUBLIC_SITE_URL=https://zinc-fusion-v16.vercel.app

# Local/server-only database connections (never NEXT_PUBLIC)
# Canonical V16 DB variable for local scripts and server checks
DATABASE_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres
# Compatibility alias for legacy script names
SUPABASE_DB_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres
# Optional pooler URL for read-heavy Python workloads
SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Optional compatibility alias exposed by some environments
POSTGRES_URL=postgresql://postgres.<project-ref>:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional direct AI provider path for Vegas Intel draft reports.
# Keep these server-only. Do not prefix with NEXT_PUBLIC_.
# OPENROUTER_API_KEY=sk-or-v1-your-personal-openrouter-key
# OPENROUTER_INTEL_MODEL=google/gemini-2.5-flash
# OPENROUTER_APP_REFERER=https://zinc-fusion-v16.vercel.app
# OPENROUTER_APP_TITLE=ZINC Fusion V16 Vegas Intel

# --- Data ingestion credentials (server/local scripts only; never NEXT_PUBLIC) ---
# Glide CRM read-only bearer token. Used by scripts/sync_vegas_glide_to_supabase.py.
# Lives in V16 only — the V15 fallback path was deleted 2026-06-11.
GLIDE_BEARER_TOKEN=your-glide-bearer-token
# FRED official API key (free, https://fred.stlouisfed.org/docs/api/api_key.html).
# Scripts use api.stlouisfed.org — the fredgraph.csv scrape endpoints are Akamai-blocked.
FRED_API_KEY=your-fred-api-key
# financialdata.net key (auth is the ?key= query parameter). Primary daily EOD
# source for ZL/ZS/ZM/CL/HO, ^VIX/^OVX, USDCNH per the 2026-06-11 pivot plan.
# Subscription must stay current — the heartbeat workflow alerts on auth failures.
FINANCIALDATA_API_KEY=your-financialdata-net-key
